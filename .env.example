# Copy to .env and fill in. The extraction core runs OFFLINE without a key
# (tabular mapping falls back to a heuristic matcher); document/PDF extraction
# and memo generation require a key.
ANTHROPIC_API_KEY=

# Optional model overrides (sensible defaults baked into config.py).
# Column-mapping is a cheap recognition task -> small model.
MAPPING_MODEL=claude-haiku-4-5-20251001
# Reading values out of factsheets wants a stronger model.
DOCUMENT_MODEL=claude-sonnet-4-6
# Memo prose -> the most capable model.
MEMO_MODEL=claude-opus-4-8

# Market data: "fixture" (default, synthetic, offline) or "live" (real yfinance
# + FRED, no API key needed). Tests always use fixture; set live for real
# benchmark/risk-free data in a demo.
MARKET_DATA=fixture
